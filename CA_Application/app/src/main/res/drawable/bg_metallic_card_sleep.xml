<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#E8F0FE"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:type="linear" android:angle="135" android:startColor="#50FFFFFF" android:centerColor="#00FFFFFF" android:endColor="#10FFFFFF"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="0.5dp" android:color="#D0D8E8"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
</layer-list>
