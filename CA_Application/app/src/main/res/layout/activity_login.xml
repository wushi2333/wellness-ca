<?xml version="1.0" encoding="utf-8"?>
<!-- Author: Liu Yu, Xia Zihang -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/loginLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background"
    android:clipToPadding="false"
    android:clipChildren="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp"
        android:clipToPadding="false"
        android:clipChildren="false">

        <!-- Language toggle -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/btnLangToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:padding="4dp"
                android:text="EN"
                android:textSize="14sp"
                android:textColor="@color/outline"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />
        </FrameLayout>

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textAppearance="@style/Heading1"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/login_subtitle"
            android:textAppearance="@style/Body"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="48dp" />

        <!-- Login form card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#FFFFFF"
            app:strokeWidth="0dp"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Username / Email -->
                <EditText
                    android:id="@+id/etUsername"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="@string/username_or_email"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:gravity="center_vertical"
                    android:textAppearance="@style/Body"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:inputType="textPersonName|textEmailAddress"
                    android:importantForAutofill="yes" />

                <TextView
                    android:id="@+id/tvUsernameError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Caption"
                    android:textColor="@color/error"
                    android:paddingStart="16dp"
                    android:paddingTop="4dp"
                    android:visibility="gone" />

                <!-- Password -->
                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="12dp"
                    android:hint="@string/password"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:gravity="center_vertical"
                    android:textAppearance="@style/Body"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:inputType="textPassword"
                    android:importantForAutofill="yes" />

                <TextView
                    android:id="@+id/tvPasswordError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Caption"
                    android:textColor="@color/error"
                    android:paddingStart="16dp"
                    android:paddingTop="4dp"
                    android:visibility="gone" />

                <!-- Login button -->
                <TextView
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:text="@string/login"
                    android:textAppearance="@style/ButtonText"
                    android:textColor="@color/on_primary"
                    android:background="@drawable/bg_btn_primary"
                    android:clickable="true"
                    android:focusable="true" />

                <!-- Error message -->
                <TextView
                    android:id="@+id/tvError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Caption"
                    android:textColor="@color/error"
                    android:visibility="gone"
                    android:paddingTop="10dp"
                    android:gravity="center" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Register link -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="18dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_no_account"
                android:textSize="14sp"
                android:textColor="@color/outline"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnRegister"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/register"
                android:textAppearance="@style/Body"
                android:textColor="@color/primary"
                android:fontWeight="700"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="4dp" />
        </LinearLayout>

        <!-- Flexible spacer pushes Google login to bottom -->
        <Space
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Divider with "其他登录方式" -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="18dp">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/divider" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/other_login_methods"
                android:textAppearance="@style/Caption"
                android:textColor="@color/outline"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/divider" />
        </LinearLayout>

        <!-- Google sign-in: white rounded square with shadow and Google G icon -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnGoogleSignIn"
            android:layout_width="52dp"
            android:layout_height="52dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            app:strokeWidth="0dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Google Sign-In">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_google_logo"
                android:importantForAccessibility="no" />
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
