<?xml version="1.0" encoding="utf-8"?>

<!--
    Item layout for a wellness record displayed in the RecyclerView.

    Theme binding:
    - background:   ?attr/selectableItemBackground (ripple from theme)
    - title:        textAppearance @style/Body (bold), color @color/text_primary
    - detail lines: textAppearance @style/Caption, color @color/text_secondary
-->

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/tvRecordDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAppearance="@style/Body"
        android:textStyle="bold"
        android:textColor="@color/text_primary" />

    <TextView
        android:id="@+id/tvSleepHours"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textAppearance="@style/Caption"
        android:textColor="@color/text_secondary" />

    <TextView
        android:id="@+id/tvExercise"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textAppearance="@style/Caption"
        android:textColor="@color/text_secondary" />

</LinearLayout>
