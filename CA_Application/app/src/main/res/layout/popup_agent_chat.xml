<?xml version="1.0" encoding="utf-8"?>
<!-- Agent chat popup for dashboard overlay -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/agentPopup"
    android:layout_width="match_parent"
    android:layout_height="400dp"
    android:layout_gravity="bottom"
    android:orientation="vertical"
    android:background="@drawable/bg_popup_top_rounded"
    android:elevation="16dp"
    android:visibility="gone">

    <!-- Header (draggable to resize) -->
    <LinearLayout
        android:id="@+id/popupHeader"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="4dp"
        android:background="@color/secondary">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Yui Agent"
            android:textAppearance="@style/Heading3"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/btnPopupVoice"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="🔊"
            android:textSize="14sp"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/btnPopupClear"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="🗑"
            android:textSize="14sp"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/btnPopupFullChat"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="↗"
            android:textSize="16sp"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/btnPopupClose"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="✕"
            android:textSize="14sp"
            android:textColor="@android:color/white" />
    </LinearLayout>

    <!-- Messages -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/popupRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"
        android:background="@color/background" />

    <!-- Input bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="6dp"
        android:gravity="center_vertical"
        android:background="@color/surface">

        <Button
            android:id="@+id/btnPopupMic"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="🎤"
            android:textSize="18sp" />

        <EditText
            android:id="@+id/etPopupMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Ask Yui…"
            android:textAppearance="@style/Body"
            android:background="@android:color/transparent"
            android:maxLines="3"
            android:paddingStart="4dp"
            android:paddingEnd="4dp" />

        <Button
            android:id="@+id/btnPopupSend"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="→"
            android:textSize="18sp" />
    </LinearLayout>
</LinearLayout>
