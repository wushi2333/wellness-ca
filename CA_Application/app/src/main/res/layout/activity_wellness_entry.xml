<?xml version="1.0" encoding="utf-8"?>

<!-- Author: Wang Songyu. Wellness entry form screen. -->

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sleep_hours"
            android:textAppearance="@style/Body"
            android:textColor="@color/text_primary" />

        <EditText
            android:id="@+id/etSleepHours"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_sleep_hours"
            android:inputType="numberDecimal" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/exercise_activity"
            android:textAppearance="@style/Body"
            android:textColor="@color/text_primary" />

        <EditText
            android:id="@+id/etExerciseActivity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_exercise_activity"
            android:inputType="text" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/exercise_duration"
            android:textAppearance="@style/Body"
            android:textColor="@color/text_primary" />

        <EditText
            android:id="@+id/etExerciseDuration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_exercise_duration"
            android:inputType="number" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/record_date"
            android:textAppearance="@style/Body"
            android:textColor="@color/text_primary" />

        <EditText
            android:id="@+id/etRecordDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="false"
            android:hint="@string/hint_select_date"
            android:inputType="none" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/notes"
            android:textAppearance="@style/Body"
            android:textColor="@color/text_primary" />

        <EditText
            android:id="@+id/etNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_notes"
            android:inputType="textMultiLine"
            android:minLines="3" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/save_record" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>
