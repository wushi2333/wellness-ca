<?xml version="1.0" encoding="utf-8"?>
<!-- Home tab: calm guidance posture. Avatar + greeting + 3 stat cards + tip. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:clipToPadding="false"
    android:paddingBottom="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp">

        <!-- ── Top bar: avatar + greeting + settings ── -->
        <LinearLayout
            android:id="@+id/homeTopBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="28dp">

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp">
                <ImageView
                    android:id="@+id/ivHomeAvatar"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_avatar_default"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_avatar_circle"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/greeting_good_morning"
                    android:textSize="13sp"
                    android:textColor="#64748B"
                    android:fontFamily="@font/segoe_ui" />

                <TextView
                    android:id="@+id/tvHomeUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/default_username"
                    android:textSize="20sp"
                    android:textColor="#1E293B"
                    android:fontFamily="@font/segoe_ui"
                    android:textStyle="bold" />
            </LinearLayout>

            <ImageView
                android:id="@+id/ivSettings"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_settings"
                android:alpha="0.35"
                android:clickable="true"
                android:focusable="true"
                android:padding="6dp" />
        </LinearLayout>

        <!-- ── Card 1: Sleep ── -->
        <LinearLayout
            android:id="@+id/cardSleep"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_sleep"
            android:padding="20dp"
            android:layout_marginBottom="14dp"
            android:elevation="1dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/sleep"
                    android:textSize="15sp"
                    android:textColor="#475569"
                    android:fontFamily="@font/segoe_ui"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💤"
                    android:textSize="20sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="bottom"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvSleepAvg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sleep_avg_placeholder"
                        android:textSize="34sp"
                        android:textColor="#2563EB"
                        android:fontFamily="@font/segoe_ui"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/avg_per_night"
                        android:textSize="12sp"
                        android:textColor="#94A3B8"
                        android:fontFamily="@font/segoe_ui"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end|bottom">

                    <TextView
                        android:id="@+id/tvSleepTrend"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="14sp"
                        android:textColor="#64748B"
                        android:fontFamily="@font/segoe_ui" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/vs_last_7d"
                        android:textSize="12sp"
                        android:textColor="#94A3B8"
                        android:fontFamily="@font/segoe_ui" />
                </LinearLayout>
            </LinearLayout>

            <!-- 7-day sleep trend sparkline -->
            <iss.nus.edu.sg.ca_application.ui.chart.SparklineView
                android:id="@+id/sparklineSleep"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />
        </LinearLayout>

        <!-- ── Card 2: Exercise ── -->
        <LinearLayout
            android:id="@+id/cardExercise"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_exercise"
            android:padding="20dp"
            android:layout_marginBottom="14dp"
            android:elevation="1dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/exercise"
                    android:textSize="15sp"
                    android:textColor="#475569"
                    android:fontFamily="@font/segoe_ui"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏃"
                    android:textSize="20sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="bottom"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvExerciseAvg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/exercise_avg_placeholder"
                        android:textSize="34sp"
                        android:textColor="#16A34A"
                        android:fontFamily="@font/segoe_ui"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/avg_per_day"
                        android:textSize="12sp"
                        android:textColor="#94A3B8"
                        android:fontFamily="@font/segoe_ui"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvExerciseDays"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/exercise_days_placeholder"
                    android:textSize="14sp"
                    android:textColor="#64748B"
                    android:fontFamily="@font/segoe_ui" />
            </LinearLayout>

            <!-- 7-day exercise activity mini bars -->
            <iss.nus.edu.sg.ca_application.ui.chart.MiniBarRowView
                android:id="@+id/miniBarExercise"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="12dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp" />
        </LinearLayout>

        <!-- ── Card 3: Recommendation ── -->
        <LinearLayout
            android:id="@+id/cardRecommendation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_default"
            android:padding="20dp"
            android:elevation="1dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/todays_tip"
                    android:textSize="15sp"
                    android:textColor="#475569"
                    android:fontFamily="@font/segoe_ui"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡"
                    android:textSize="18sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvLatestTip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/default_tip_text"
                android:textSize="14sp"
                android:textColor="#64748B"
                android:fontFamily="@font/segoe_ui"
                android:lineSpacingMultiplier="1.3" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
