<?xml version="1.0" encoding="utf-8"?>
<!-- Chat tab: DrawerLayout for session sidebar + main chat area -->
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F8FAFC">

        <!-- Live2D area -->
        <FrameLayout
            android:id="@+id/live2dContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="4"
            android:background="#FFFFFF">

            <iss.nus.edu.sg.ca_application.live2d.Live2DCharacterView
                android:id="@+id/live2dView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </FrameLayout>

        <!-- Mode + Voice + Session bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="#FFFFFF">

            <TextView
                android:id="@+id/tvSessionTitle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/new_chat"
                android:textSize="14sp"
                android:textColor="#1E293B"
                android:fontFamily="@font/segoe_ui"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <Button
                android:id="@+id/btnModeToggle"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="@string/chat"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:background="@drawable/bg_btn_chat"
                android:elevation="0dp" />

            <Button
                android:id="@+id/btnToggleVoice"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="🔊"
                android:textSize="12sp"
                android:textColor="#1E293B"
                android:minWidth="0dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_input_field"
                android:elevation="0dp" />

            <Button
                android:id="@+id/btnSessions"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="☰"
                android:textSize="14sp"
                android:textColor="#1E293B"
                android:minWidth="0dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_input_field"
                android:elevation="0dp" />
        </LinearLayout>

        <!-- Message list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/chatRecycler"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="4"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:clipToPadding="false" />

        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#E2E8F0" />

        <!-- Input bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:background="#FFFFFF">

            <ImageButton android:id="@+id/btnChatMic" android:layout_width="44dp" android:layout_height="44dp"
                android:src="@drawable/ic_mic" android:background="@android:color/transparent"
                android:elevation="0dp" android:scaleType="center" android:padding="8dp" />

            <EditText android:id="@+id/etChatMessage" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:hint="@string/chat_hint"
                android:textSize="15sp" android:textColor="#1E293B" android:textColorHint="#94A3B8"
                android:fontFamily="@font/segoe_ui" android:background="@drawable/bg_input_field"
                android:paddingStart="14dp" android:paddingEnd="14dp" android:paddingTop="10dp" android:paddingBottom="10dp"
                android:maxLines="3" android:inputType="textCapSentences|textAutoCorrect" />

            <ImageButton android:id="@+id/btnChatSend" android:layout_width="44dp" android:layout_height="44dp"
                android:src="@drawable/ic_send" android:background="@android:color/transparent" android:padding="8dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Session sidebar (right side, 280dp) -->
    <LinearLayout
        android:id="@+id/sidebarDrawer"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:background="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:background="#F8FAFC">

            <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                android:text="@string/history_title" android:textSize="16sp" android:textColor="#1E293B"
                android:fontFamily="@font/segoe_ui" android:textStyle="bold" />

            <ImageButton android:id="@+id/btnTrash" android:layout_width="36dp" android:layout_height="36dp"
                android:src="@drawable/ic_trash" android:background="@android:color/transparent" android:padding="6dp" />

            <Button android:id="@+id/btnNewChat" android:layout_width="wrap_content" android:layout_height="32dp"
                android:text="@string/new_chat_button" android:textSize="12sp" android:minWidth="0dp"
                android:paddingStart="10dp" android:paddingEnd="10dp" android:background="@drawable/bg_input_field" android:elevation="0dp" />
        </LinearLayout>

        <!-- Selection actions -->
        <LinearLayout android:id="@+id/layoutSelectionActions" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="horizontal"
            android:padding="8dp" android:visibility="gone" android:background="#FEF2F2">

            <Button android:id="@+id/btnDeleteSelected" android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="36dp" android:text="@string/delete_selected" android:textSize="12sp"
                android:textColor="#EF4444" android:background="@android:color/transparent" android:elevation="0dp" />

            <Button android:id="@+id/btnDeleteAll" android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="@string/delete_all" android:textSize="12sp"
                android:textColor="#EF4444" android:background="@android:color/transparent" android:elevation="0dp" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/sessionRecycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
