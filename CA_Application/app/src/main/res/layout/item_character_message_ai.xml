<?xml version="1.0" encoding="utf-8"?>
<!-- Author: Xia Zihang -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start"
    android:paddingEnd="48dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvEmotion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/Caption"
            android:textColor="@color/text_hint"
            android:textSize="10sp"
            android:paddingStart="4dp"
            android:paddingBottom="2dp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/layoutBubble"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_bubble_ai"
            android:alpha="0.72"
            android:padding="12dp"
            android:minWidth="60dp"
            android:minHeight="40dp">

            <TextView
                android:id="@+id/tvContent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/Body"
                android:textColor="@color/bubble_ai_text"
                android:maxWidth="260dp"
                android:textIsSelectable="true"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/progressLoading"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:indeterminateTint="@color/text_hint"
                android:layout_gravity="center"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Tools toggle — only visible in agent mode when tools are used -->
        <TextView
            android:id="@+id/tvToolsToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/Caption"
            android:textColor="@color/text_hint"
            android:textSize="11sp"
            android:paddingStart="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="2dp"
            android:visibility="gone"
            android:text="tools▸" />

        <!-- Tools list — shown when expanded -->
        <LinearLayout
            android:id="@+id/layoutToolsList"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingBottom="2dp"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
