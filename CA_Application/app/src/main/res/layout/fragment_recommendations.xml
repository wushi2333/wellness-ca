<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/background">

    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:gravity="center_vertical" android:paddingStart="8dp" android:paddingEnd="16dp"
        android:background="@color/surface" android:elevation="2dp">
        <ImageView android:id="@+id/btnRecsBack" android:layout_width="24dp"
            android:layout_height="24dp" android:src="@drawable/ic_back" />
        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
            android:layout_marginStart="12dp" android:text="@string/recommendations_title" android:textAppearance="@style/Heading3"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical" android:padding="16dp">

        <Button android:id="@+id/btnGenerateRec" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="@string/generate_new_recommendation"
            android:textColor="#FFFFFF" android:backgroundTint="@null"
            android:background="@drawable/bg_btn_primary"/>
        <ProgressBar android:id="@+id/progressRecs" android:layout_width="24dp"
            android:layout_height="24dp" android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp" android:visibility="gone"/>
        <TextView android:id="@+id/tvRecsResult" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginTop="16dp"
            android:background="@drawable/bg_metallic_card" android:padding="16dp"
            android:textAppearance="@style/Body" android:textColor="@color/text_primary"
            android:visibility="gone"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:orientation="vertical">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="16dp" android:text="@string/history_title" android:textAppearance="@style/Heading3"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recsHistoryRecycler" android:layout_width="match_parent"
                android:layout_height="0dp" android:layout_weight="1" android:layout_marginTop="8dp"/>

            <LinearLayout android:id="@+id/paginationBar" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:gravity="center"
                android:orientation="horizontal" android:layout_marginTop="16dp"
                android:visibility="gone">

                <TextView android:id="@+id/btnFirstPage" android:layout_width="36dp"
                    android:layout_height="36dp" android:gravity="center" android:text="«"
                    android:textSize="14sp" android:textStyle="bold" android:textColor="#1E293B"
                    android:background="@drawable/bg_input_field" android:clickable="true"
                    android:layout_marginEnd="4dp"/>

                <TextView android:id="@+id/btnPrevPage" android:layout_width="36dp"
                    android:layout_height="36dp" android:gravity="center" android:text="‹"
                    android:textSize="16sp" android:textStyle="bold" android:textColor="#1E293B"
                    android:background="@drawable/bg_input_field" android:clickable="true"
                    android:layout_marginEnd="8dp"/>

                <TextView android:id="@+id/tvPageInfo" android:layout_width="wrap_content"
                    android:layout_height="36dp" android:gravity="center"
                    android:text="1 / 1" android:textSize="13sp" android:textColor="#64748B"
                    android:fontFamily="@font/segoe_ui" android:layout_marginEnd="4dp"/>

                <EditText android:id="@+id/etPageJump" android:layout_width="48dp"
                    android:layout_height="36dp" android:gravity="center"
                    android:inputType="number" android:textSize="13sp" android:textColor="#1E293B"
                    android:textColorHint="#94A3B8" android:background="@drawable/bg_input_field"
                    android:layout_marginEnd="4dp"/>

                <TextView android:id="@+id/btnGoPage" android:layout_width="36dp"
                    android:layout_height="36dp" android:gravity="center" android:text="Go"
                    android:textSize="12sp" android:textStyle="bold" android:textColor="#007AFF"
                    android:background="@drawable/bg_input_field" android:clickable="true"
                    android:layout_marginEnd="8dp"/>

                <TextView android:id="@+id/btnNextPage" android:layout_width="36dp"
                    android:layout_height="36dp" android:gravity="center" android:text="›"
                    android:textSize="16sp" android:textStyle="bold" android:textColor="#1E293B"
                    android:background="@drawable/bg_input_field" android:clickable="true"
                    android:layout_marginEnd="4dp"/>

                <TextView android:id="@+id/btnLastPage" android:layout_width="36dp"
                    android:layout_height="36dp" android:gravity="center" android:text="»"
                    android:textSize="14sp" android:textStyle="bold" android:textColor="#1E293B"
                    android:background="@drawable/bg_input_field" android:clickable="true"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
