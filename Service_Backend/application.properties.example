# Author: Yutong Luo
# Copy these values to environment variables on the server.
# Do not commit real passwords, API keys, or JWT secrets.

server.port=8000

DB_HOST=your-mysql-host
DB_PORT=3306
DB_NAME=wellness_ca
DB_USER=your-db-user
DB_PASSWORD=your-db-password

# Use at least 32 characters for HS256.
JWT_SECRET_KEY=replace-with-at-least-32-random-characters
ACCESS_TOKEN_EXPIRE_MINUTES=1440

API_GATEWAY_TOKEN=replace-with-team-gateway-token
DEEPSEEK_API_KEY=replace-with-server-only-deepseek-key
