# DeepSeek API — get from https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-key-here

# Safety Gateway Token — team shared secret
API_GATEWAY_TOKEN=team-wellness-2025

# JWT Parameters
JWT_SECRET_KEY=generate-with-python-secrets-token-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Aiven MySQL — get from Aiven Console > wellness-ca > Overview
DB_HOST=your-host.aivencloud.com
DB_PORT=24661
DB_USER=avnadmin
DB_PASSWORD=your-password-here
DB_NAME=wellness_ca

# Aiven SSL CA certificate (on server)
DB_SSL_CA=/home/wellness-dev/wellness-backend/ca.pem
